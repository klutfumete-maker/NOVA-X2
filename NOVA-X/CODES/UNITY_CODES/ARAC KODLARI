using System.Collections;
using System.Collections.Generic;
using UnityEngine;

public class OtonomGorev : MonoBehaviour
{
    [Header("Model Ayarı")]
    public bool modelTersMi = false;

    [Header("Yörünge Ayarları")]
    public float devriyeHizi = 15f;
    public float donusHizi = 8f;
    public float dunyaMesafe = 100f;

    [Header("Lazer ve Operasyon")]
    public float algilamaMesafesi = 30f;
    public float firlatmaSiniri = 80f;
    public float burunUzunlugu = 2.5f;
    public float lazerKalinligi = 0.4f;
    public float itmeHizi = 8f;

    [Header("Görsel Efektler")]
    public GameObject dunyaEkrani;
    public float ekranGosterimSuresi = 4f;

    // Renkleri Inspector'dan daha fosforlu seçebilirsin
    public Color taramaRengi = Color.yellow;
    public Color guvenliRenk = Color.green;
    public Color imhaRengi = Color.red;

    private Transform dunya;
    private Transform uyduMerkezi;
    private LineRenderer lazer;

    private bool mesgul = false;
    private Transform aktifHedef;
    private List<Transform> tarananUydular = new List<Transform>();

    void Start()
    {
        GameObject dunyaObj = GameObject.FindGameObjectWithTag("Dunya");
        if (dunyaObj) dunya = dunyaObj.transform;

        GameObject uyduObj = GameObject.FindGameObjectWithTag("Uydu");
        if (uyduObj) uyduMerkezi = uyduObj.transform;

        lazer = GetComponent<LineRenderer>();
        if (!lazer) lazer = gameObject.AddComponent<LineRenderer>();

        lazer.material = new Material(Shader.Find("Unlit/Color")) { color = Color.red };

        lazer.startWidth = lazerKalinligi;
        lazer.endWidth = lazerKalinligi;

        lazer.positionCount = 2;
        lazer.enabled = false;
        lazer.useWorldSpace = true;

        if (dunyaEkrani != null) dunyaEkrani.SetActive(false);
    }

    void Update()
    {
        if (dunya == null) return;

        if (!mesgul)
        {
            YorungedeKal();
            CisimAra();
        }

        CopYorungesiniYonet();
    }

    void YorungedeKal()
    {
        Vector3 yon = (transform.position - dunya.position).normalized;
        Vector3 teget = Vector3.Cross(Vector3.up, yon).normalized;
        float sapma = dunyaMesafe - Vector3.Distance(transform.position, dunya.position);
        Vector3 hedefYon = (teget + yon * sapma * 0.15f).normalized;

        Don(hedefYon);
        Ilerle(devriyeHizi);
    }

    void CopYorungesiniYonet()
    {
        GameObject[] copler = GameObject.FindGameObjectsWithTag("Cop");
        foreach (var cop in copler)
        {
            if (cop == null || (aktifHedef != null && cop.transform == aktifHedef)) continue;

            Vector3 yon = (cop.transform.position - dunya.position).normalized;
            Vector3 teget = Vector3.Cross(Vector3.up, yon).normalized;
            float sapma = 85f - Vector3.Distance(cop.transform.position, dunya.position);
            Vector3 hareket = (teget + yon * sapma * 0.1f).normalized;

            cop.transform.position += hareket * (devriyeHizi * 0.5f) * Time.deltaTime;
        }
    }

    void CisimAra()
    {
        GameObject[] copler = GameObject.FindGameObjectsWithTag("Cop");
        GameObject[] uydular = GameObject.FindGameObjectsWithTag("AktifUydu");

        List<GameObject> adaylar = new List<GameObject>(copler);
        adaylar.AddRange(uydular);

        foreach (var obj in adaylar)
        {
            if (obj == null || tarananUydular.Contains(obj.transform)) continue;

            if (Vector3.Distance(transform.position, obj.transform.position) < algilamaMesafesi)
            {
                aktifHedef = obj.transform;
                StartCoroutine(GorevAkisi());
                break;
            }
        }
    }

    // --- YENİ: CİSMİN TÜM PARÇALARINI BOYAYAN FONKSİYON ---
    void HedefiKompleBoya(Transform hedef, Color yeniRenk)
    {
        if (hedef == null) return;

        // Hedefin içindeki bütün alt parçaları (Renderer'ları) bulur
        Renderer[] tumParcalar = hedef.GetComponentsInChildren<Renderer>();

        foreach (Renderer parca in tumParcalar)
        {
            // Eğer objenin birden fazla materyali varsa hepsini boyar
            foreach (Material mat in parca.materials)
            {
                mat.color = yeniRenk;

                // Eğer materyal destekliyorsa biraz da parlama (Emission) ekler
                if (mat.HasProperty("_EmissionColor"))
                {
                    mat.EnableKeyword("_EMISSION");
                    mat.SetColor("_EmissionColor", yeniRenk * 1.5f);
                }
            }
        }
    }

    IEnumerator GorevAkisi()
    {
        mesgul = true;

        // CİSMİ KOMPLE SARIYA BOYA (Tarama Başladı)
        HedefiKompleBoya(aktifHedef, taramaRengi);

        // 1. VERİ AKIŞI
        if (uyduMerkezi != null)
        {
            yield return StartCoroutine(VeriGonder(transform.position, uyduMerkezi.position));
            yield return StartCoroutine(VeriGonder(uyduMerkezi.position, dunya.position));
            yield return StartCoroutine(VeriGonder(dunya.position, uyduMerkezi.position));
            yield return StartCoroutine(VeriGonder(uyduMerkezi.position, transform.position));
        }

        // 2. EKRANI GÖSTER
        if (dunyaEkrani != null)
        {
            StartCoroutine(EkranGosterVeKapat());
        }

        // 3. AKTİF UYDU İSE (GÜVENLİ)
        if (aktifHedef != null && aktifHedef.CompareTag("AktifUydu"))
        {
            // CİSMİ KOMPLE YEŞİLE BOYA
            HedefiKompleBoya(aktifHedef, guvenliRenk);

            tarananUydular.Add(aktifHedef);
            aktifHedef = null;
            mesgul = false;
            yield break;
        }

        // 4. ÇÖP İSE (İMHA VE İTME)
        if (aktifHedef != null && aktifHedef.CompareTag("Cop"))
        {
            // CİSMİ KOMPLE KIRMIZIYA BOYA
            HedefiKompleBoya(aktifHedef, imhaRengi);

            lazer.enabled = true;

            while (aktifHedef != null && Vector3.Distance(aktifHedef.position, dunya.position) > firlatmaSiniri)
            {
                Vector3 hedefeYon = (aktifHedef.position - transform.position).normalized;
                Don(hedefeYon);

                if (Vector3.Distance(transform.position, aktifHedef.position) > 8f)
                    Ilerle(devriyeHizi * 1.2f);

                Vector3 burunPoz = transform.position + (modelTersMi ? -transform.forward : transform.forward) * burunUzunlugu;
                lazer.SetPosition(0, burunPoz);
                lazer.SetPosition(1, aktifHedef.position);

                Vector3 dunyaItmeYonu = (dunya.position - aktifHedef.position).normalized;
                aktifHedef.position += dunyaItmeYonu * itmeHizi * Time.deltaTime;

                yield return null;
            }
        }

        lazer.enabled = false;
        if (aktifHedef != null) Destroy(aktifHedef.gameObject);

        aktifHedef = null;
        mesgul = false;
    }

    IEnumerator EkranGosterVeKapat()
    {
        dunyaEkrani.SetActive(true);
        yield return new WaitForSeconds(ekranGosterimSuresi);
        dunyaEkrani.SetActive(false);
    }

    IEnumerator VeriGonder(Vector3 bas, Vector3 bit)
    {
        GameObject v = GameObject.CreatePrimitive(PrimitiveType.Sphere);
        if (v.GetComponent<Collider>()) Destroy(v.GetComponent<Collider>());
        v.GetComponent<Renderer>().material.color = Color.cyan;
        v.transform.position = bas;
        v.transform.localScale = Vector3.one * 1.2f;

        while (v != null && Vector3.Distance(v.transform.position, bit) > 1f)
        {
            v.transform.position = Vector3.MoveTowards(v.transform.position, bit, 120f * Time.deltaTime);
            yield return null;
        }
        Destroy(v);
    }

    void Don(Vector3 yon)
    {
        if (yon == Vector3.zero) return;
        Vector3 bakiYonu = modelTersMi ? -yon : yon;
        Quaternion hedefRot = Quaternion.LookRotation(bakiYonu);
        transform.rotation = Quaternion.Slerp(transform.rotation, hedefRot, donusHizi * Time.deltaTime);
    }

    void Ilerle(float h)
    {
        Vector3 ileri = modelTersMi ? -transform.forward : transform.forward;
        transform.position += ileri * h * Time.deltaTime;
        transform.position = new Vector3(transform.position.x, 0, transform.position.z);
    }
}
