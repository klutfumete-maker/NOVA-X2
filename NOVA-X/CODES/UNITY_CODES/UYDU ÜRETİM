using UnityEngine;

public class UzayTrafigi : MonoBehaviour
{
    public GameObject copPrefab;
    public GameObject aktifUyduPrefab;
    public Transform arac;
    public Transform dunya;

    public float uretimSuresi = 3f;
    public float yorungeMesafesi = 200f;
    public int maksimumCisim = 12; // Birikmeyi önleyen sınır

    private float sabitY;

    void Start()
    {
        if (arac != null) sabitY = arac.position.y;
        InvokeRepeating("IlerideObjeUret", 2f, uretimSuresi);
    }

    void IlerideObjeUret()
    {
        if (arac == null || dunya == null) return;

        // Sahne kontrolü: Etrafta çok cisim varsa üretimi duraklat (Birikmeyi önler)
        int mevcutCisim = GameObject.FindGameObjectsWithTag("Cop").Length + GameObject.FindGameObjectsWithTag("AktifUydu").Length;
        if (mevcutCisim >= maksimumCisim) return;

        Vector3 aracinYonu = (arac.position - dunya.position).normalized;

        // Aracın sadece 30-50 derece ilerisinde (burnunun ucunda) üret
        float ileriAci = Random.Range(30f, 50f);
        Quaternion donus = Quaternion.Euler(0, ileriAci, 0);
        Vector3 uretimYonu = donus * aracinYonu;

        Vector3 uretimNoktasi = dunya.position + (uretimYonu * yorungeMesafesi);
        uretimNoktasi.y = sabitY;

        bool copMu = Random.value > 0.5f;
        GameObject secilenPrefab = copMu ? copPrefab : aktifUyduPrefab;
        string secilenTag = copMu ? "Cop" : "AktifUydu";

        GameObject yeniObje = Instantiate(secilenPrefab, uretimNoktasi, Quaternion.identity);
        yeniObje.tag = secilenTag;
    }
}
