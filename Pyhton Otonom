import serial
import time
import RPi.GPIO as GPIO
import requests # Gerçek API istekleri için eklendi

# --- AYARLAR ---
ARDUINO_PORT = '/dev/ttyUSB0'
BAUD_RATE = 115200
MOSFET_PIN = 17 # Lazer Ateşleme

NORMAL_MANYETIK_ALAN = 50.0 # uT
ANOMALI_ESIGI = 80.0 # uT (Bu değerin üstü metalik kütle/çöp demektir)

class OtonomUzayAraci:
    def __init__(self):
        print("=== SİSTEM BAŞLATILIYOR ===")
        # GPIO Ayarları (Yalnızca Raspberry Pi üzerinde çalışırken aktiftir)
        try:
            GPIO.setmode(GPIO.BCM)
            GPIO.setwarnings(False)
            GPIO.setup(MOSFET_PIN, GPIO.OUT)
            GPIO.output(MOSFET_PIN, GPIO.LOW) # Lazer Kapalı
        except Exception as e:
            print(f"[UYARI] GPIO Pinleri başlatılamadı (Muhtemelen PC'de çalışıyorsunuz): {e}")
        
        self.kapasitor_sarj = 0.0 # RTG Enerjisi
        
        try:
            self.arduino = serial.Serial(ARDUINO_PORT, BAUD_RATE, timeout=0.1)
            time.sleep(2)
            print("[OK] Arduino Bağlantısı Kuruldu.")
        except:
            print("[HATA] Arduino Bulunamadı! Simülasyon modunda devam ediliyor...")
            self.arduino = None

    def kapasitoru_sarj_et(self):
        # Nükleer batarya (RTG) her döngüde %2 şarj eder
        if self.kapasitor_sarj < 100.0:
            self.kapasitor_sarj += 2.0
            if self.kapasitor_sarj > 100.0: self.kapasitor_sarj = 100.0

    def arduino_veri_oku(self):
        # Arduino'dan gelen manyetik alan ortalamasını yakalar
        if self.arduino and self.arduino.in_waiting > 0:
            try:
                veri = self.arduino.readline().decode('utf-8').strip()
                if "ONAY" not in veri and veri != "":
                    return float(veri)
            except ValueError:
                pass
        # Arduino yoksa test için manuel anomali simülasyonu yapabiliriz, şimdilik normal dönüyor
        return NORMAL_MANYETIK_ALAN

    def uzay_veritabani_sorgula(self, norad_id="40258"):
        """
        Gerçek CelesTrak API'sini kullanarak hedefin aktif bir uydu olup olmadığını kontrol eder.
        Varsayılan NORAD ID 40258 (TÜRKSAT 4A) olarak ayarlandı.
        """
        print("\n[TELEMETRİ] Hedef Yörünge Analizi Yapılıyor...")
        print("[TELEMETRİ] CelesTrak/USSPACECOM Canlı Veritabanına Bağlanılıyor...")
        
        try:
            # Gerçek veri: Belirtilen NORAD ID'sine ait TLE (yörünge) parametrelerini çeker
            url = f"https://celestrak.org/NORAD/elements/gp.php?CATNR={norad_id}&FORMAT=json"
            response = requests.get(url, timeout=5)
            
            if response.status_code == 200:
                veri = response.json()
                if len(veri) > 0:
                    uydu_adi = veri[0].get('OBJECT_NAME', 'Bilinmeyen Uydu')
                    print(f"[DURUM] TLE Eşleşmesi Bulundu: {uydu_adi} (Aktif Uydu).")
                    return "AKTIF"
                else:
                    print("[DURUM] TLE Eşleşmesi YOK. Hedef: KAYITSIZ UZAY ÇÖPÜ!")
                    return "COP"
            else:
                # Eğer API yanıt vermezse Güvenli Mod (Fail-Safe) devreye girer.
                print("[HATA] Uzay Komutanlığı veritabanına erişilemiyor!")
                print("[DURUM] Fail-Safe devrede: Hedef sivil uydu kabul edildi.")
                return "AKTIF" 
                
        except requests.exceptions.RequestException as e:
            print(f"[HATA] Bağlantı sorunu: {e}")
            print("[DURUM] Fail-Safe devrede: Yanlışlıkla bir uyduyu vurmamak için pas geçiliyor.")
            return "AKTIF"

    def arduino_komut_gonder(self, komut):
        if self.arduino:
            self.arduino.write(f"{komut}\n".encode('utf-8'))

    def ana_dongu(self):
        # Test amaçlı sahte bir anomali tetikleyici sayacı
        test_sayaci = 0 
        
        while True:
            # ADIM 1: İZLE VE ŞARJ ET
            self.kapasitoru_sarj_et()
            manyetik_alan = self.arduino_veri_oku()
            
            # (Test için 50. döngüde manuel bir uzay çöpü anomalisi yaratalım)
            test_sayaci += 1
            if test_sayaci == 50 and not self.arduino:
                manyetik_alan = 95.0
            
            print(f"[İzleme] Manyetik Alan: {manyetik_alan:.1f} uT | Kapasitör: %{self.kapasitor_sarj:.0f}", end='\r')
            
            # ADIM 2: ANOMALİ TESPİTİ
            if manyetik_alan > ANOMALI_ESIGI:
                print(f"\n\n[ALARM] ANORMAL MANYETİK KÜTLE TESPİT EDİLDİ! (Değer: {manyetik_alan:.1f} uT)")
                
                # ADIM 3: HEDEF DOĞRULAMA (Gerçek API)
                # Test_sayaci 50 olduğunda bilerek geçersiz bir ID (00000) gönderip uzay çöpü sonucu alalım
                test_id = "00000" if test_sayaci == 50 else "40258"
                hedef_turu = self.uzay_veritabani_sorgula(norad_id=test_id)
                
                # ADIM 4: KARAR MEKANİZMASI
                if hedef_turu == "AKTIF":
                    print("[KARAR] Güvenli Mesafe Korunuyor. Pas geçiliyor.\n")
                    time.sleep(2)
                    manyetik_alan = NORMAL_MANYETIK_ALAN # Sensörü sıfırla
                    continue 
                    
                elif hedef_turu == "COP":
                    # ADIM 5: HİZALANMA VE YAKALAMA
                    print("[SİSTEM] İmha Protokolü Başlatıldı!")
                    print("[HAREKET] Arduino'ya L298N Elektromıknatısları Aktif Etme Emri Verildi.")
                    self.arduino_komut_gonder("MIKNATIS_AC")
                    time.sleep(2) 
                    
                    # ADIM 6: ATEŞLEME
                    while self.kapasitor_sarj < 100.0:
                        print(f"[GÜÇ] Ateşleme için kapasitör bekleniyor... %{self.kapasitor_sarj:.0f}")
                        self.kapasitoru_sarj_et()
                        time.sleep(0.5)
                        
                    print("\n!!! ATEŞLEME !!!")
                    print("[SİSTEM] MOSFET Tetiklendi. Lazer Çöpü Atmosfere İtiyor!")
                    try:
                        GPIO.output(MOSFET_PIN, GPIO.HIGH)
                    except: pass
                    time.sleep(2.5) 
                    
                    # ADIM 7: SIFIRLAMA
                    print("[SİSTEM] Lazer Kapatıldı. Kapasitör Boşaltıldı.")
                    try:
                        GPIO.output(MOSFET_PIN, GPIO.LOW)
                    except: pass
                    self.kapasitor_sarj = 0.0
                    
                    print("[HAREKET] Elektromıknatıslar Kapatılıyor. Devriyeye Dönülüyor.\n")
                    self.arduino_komut_gonder("MIKNATIS_KAPAT")
                    time.sleep(2)
                    test_sayaci = 0 # Test döngüsünü başa sar
            
            time.sleep(0.1)

if __name__ == '__main__':
    try:
        arac = OtonomUzayAraci()
        arac.ana_dongu()
    except KeyboardInterrupt:
        print("\n[SİSTEM] Manuel olarak durduruldu.")
        try:
            GPIO.cleanup()
        except: pass
